# Backend Java / Tomcat
# Copie para .env no ambiente local ou cadastre essas variaveis no host da API.

# Local Docker:
DB_JDBC_URL=jdbc:postgresql://localhost:5432/site_discos
DB_USER=postgres
DB_PASSWORD=123456

# Supabase:
# Use a connection string JDBC do Supabase. Normalmente precisa de sslmode=require.
# DB_JDBC_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# DB_USER=postgres.seu-project-ref
# DB_PASSWORD=sua-senha-do-banco

# Token da API do Discogs.
DISCOGS_TOKEN=coloque-seu-token-discogs-aqui

# Origens autorizadas a chamar a API com cookie/sessao.
# Inclua o GitHub Pages e os ambientes locais separados por virgula.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yeslei.github.io

# Frontend Vite / GitHub Pages
# Local: use frontend/.env
# GitHub Actions: cadastre VITE_API_URL em Settings > Secrets and variables > Actions > Variables
VITE_API_URL=http://localhost:8080/backend
