# Backend Java / Tomcat
# Copie para .env no ambiente local ou cadastre essas variaveis no host da API.

# Local Docker:
DB_JDBC_URL=jdbc:postgresql://localhost:5432/site_discos
DB_USER=postgres
DB_PASSWORD=123456

# Supabase:
# Use a connection string JDBC do Supabase. Normalmente precisa de sslmode=require.
# DB_JDBC_URL=jdbc:postgresql://db.seu-project-ref.supabase.co:5432/postgres?sslmode=require
# DB_USER=postgres
# DB_PASSWORD=sua-senha-do-banco
#
# Alternativa para Railway/Supabase: uma unica variavel DATABASE_URL.
# Se a senha tiver caracteres especiais, prefira DB_JDBC_URL + DB_USER + DB_PASSWORD.
# DATABASE_URL=postgresql://postgres:sua-senha-do-banco@db.seu-project-ref.supabase.co:5432/postgres
#
# Tambem funciona DB_JDBC_URL com user/password na propria URL, embora seja menos claro:
# DB_JDBC_URL=jdbc:postgresql://db.seu-project-ref.supabase.co:5432/postgres?user=postgres&password=sua-senha-do-banco&sslmode=require

# Token da API do Discogs.
DISCOGS_TOKEN=coloque-seu-token-discogs-aqui

# Origens autorizadas a chamar a API com cookie/sessao.
# Inclua o GitHub Pages e os ambientes locais separados por virgula.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yeslei.github.io

# Cookies de sessao entre GitHub Pages e API em outro dominio.
SESSION_COOKIE_SAMESITE_NONE=true
SESSION_COOKIE_SECURE=auto

# Frontend Vite / GitHub Pages
# Local: use frontend/.env
# GitHub Actions: cadastre VITE_API_URL em Settings > Secrets and variables > Actions > Variables
VITE_API_URL=http://localhost:8080/backend
