<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>MeuAcervo API</display-name>

    <request-character-encoding>UTF-8</request-character-encoding>
    <response-character-encoding>UTF-8</response-character-encoding>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ================================================================
         Cadeia de filtros declarada AQUI (e nao via @WebFilter) para
         garantir a ORDEM. A ordem das <filter-mapping> e respeitada:
         1) CORS  -> precisa rodar primeiro para que ate respostas 401
                     saiam com os headers de CORS (senao o navegador
                     bloqueia a leitura do erro pelo React).
         2) Encoding -> UTF-8 em tudo.
         3) Auth  -> bloqueia rotas protegidas devolvendo 401 JSON.
         ================================================================ -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.seusite.discos.security.CorsFilter</filter-class>
    </filter>
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.seusite.discos.security.EncodingFilter</filter-class>
    </filter>
    <filter>
        <filter-name>SessionCookieFilter</filter-name>
        <filter-class>com.seusite.discos.security.SessionCookieFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.seusite.discos.security.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>SessionCookieFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Rotas que exigem login. /api/me NAO entra aqui: ele mesmo decide. -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/home</url-pattern>
        <url-pattern>/buscar-discos</url-pattern>
        <url-pattern>/disco/abrir</url-pattern>
        <url-pattern>/disco/metricas</url-pattern>
        <url-pattern>/ver-tracklist</url-pattern>
        <url-pattern>/avaliar-disco</url-pattern>
        <url-pattern>/colecao/ver</url-pattern>
        <url-pattern>/colecao/listar</url-pattern>
        <url-pattern>/colecao/criar</url-pattern>
        <url-pattern>/colecao/adicionar</url-pattern>
        <url-pattern>/perfil/reviews</url-pattern>
        <url-pattern>/wishlist/adicionar</url-pattern>
        <url-pattern>/wishlist/remover</url-pattern>
        <url-pattern>/wishlist/listar</url-pattern>
        <url-pattern>/feed</url-pattern>
        <url-pattern>/post</url-pattern>
        <url-pattern>/criar-post</url-pattern>
        <url-pattern>/curtir-post</url-pattern>
    </filter-mapping>

</web-app>
