meta {
  name: Remover Disco
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/colecao/adicionar
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "id_disco": {{idDisco}}
  }
}

tests {
  test("remover colecao usa DELETE", function () {
    expect([200, 400, 401, 500]).to.include(res.status);
  });
}
