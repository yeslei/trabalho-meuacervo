meta {
  name: Atualizar Detalhes
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/colecao/adicionar
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "id_disco": {{idDisco}},
    "estado": "Bom",
    "observacao": "Nota privada de exemplo."
  }
}

tests {
  test("atualizar detalhes da colecao usa PUT", function () {
    expect([200, 400, 401, 500]).to.include(res.status);
  });
}
